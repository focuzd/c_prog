#include <stdio.h>

#define N 5

int main(void)
{
    int m[N][N], i, j, high, low;
    long sum;
    double avg;

    for (i = 0; i < N; i++) {
        printf("Enter grades for quiz %d: ", i + 1);
        for (j = 0; j < N; j++) {
            scanf("%d", &m[i][j]);
        }
    }

    for (i = 0; i < N; i++) {
        printf("Quiz %d:\n", i + 1);
        sum = 0;
        high = low = m[i][0];
        for (j = 0; j < N; j++) {
            sum += m[i][j];
            if (m[i][j] < low) {
                low = m[i][j];
            }
            if (m[i][j] > high) {
                high = m[i][j];
            }
        }
        printf("Average score: %lf\n", sum / 5.0);
        printf("High score: %d\nLow score: %d\n", high, low);
    }

    printf("Student Avg. Score Total Score\n");
    for (i = 0; i < N; i++) {
        sum = 0;
        for (j = 0; j < N; j++) {
            sum += m[j][i];
        }
        printf("%-7d %-10d %-10d\n", i+1, sum / 5.0, sum);
    }
    
    return 0;
}
